 	}
 }
 
-// VoiceCapabilities returns the voice capabilities of the channel.
+func (c *DiscordChannel) OpenThread(ctx context.Context, channelID, name, initialMessage string) (string, error) {
+	msg, err := c.session.ChannelMessageSend(channelID, initialMessage)
+	if err != nil {
+		return "", fmt.Errorf("discord open thread: send anchor: %w", err)
+	}
+
+	thread, err := c.session.MessageThreadStartComplex(channelID, msg.ID, &discordgo.ThreadStart{
+		Name:                name,
+		AutoArchiveDuration: 60,
+	})
+	if err != nil {
+		// Best-effort cleanup of orphaned anchor message.
+		_ = c.session.ChannelMessageDelete(channelID, msg.ID)
+		return "", fmt.Errorf("discord open thread: create thread: %w", err)
+	}
+	return thread.ID, nil
+}
+
+func (c *DiscordChannel) SendToThread(ctx context.Context, threadID, content string) (string, error) {
+	msg, err := c.session.ChannelMessageSend(threadID, content)
+	if err != nil {
+		return "", fmt.Errorf("discord send to thread: %w", err)
+	}
+	return msg.ID, nil
+}
+
 func (c *DiscordChannel) VoiceCapabilities() channels.VoiceCapabilities {
 	return channels.VoiceCapabilities{ASR: true, TTS: true}
 }
