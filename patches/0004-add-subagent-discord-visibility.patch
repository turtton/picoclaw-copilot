diff --git a/pkg/gateway/subturn_notifier.go b/pkg/gateway/subturn_notifier.go
new file mode 100644
--- /dev/null
+++ b/pkg/gateway/subturn_notifier.go
@@ -0,0 +1,521 @@
+package gateway
+
+import (
+	"context"
+	"encoding/json"
+	"fmt"
+	"strings"
+	"sync"
+	"time"
+	"unicode"
+
+	"github.com/sipeed/picoclaw/pkg/agent"
+	"github.com/sipeed/picoclaw/pkg/channels"
+	"github.com/sipeed/picoclaw/pkg/logger"
+)
+
+// turnInfo maps a parent turn to the channel it originated from.
+type turnInfo struct {
+	channel string
+	chatID  string
+}
+
+// subturnEntry tracks a single subturn's thread lifecycle.
+// Owned exclusively by workerLoop.
+type subturnEntry struct {
+	label    string
+	channel  string
+	chatID   string
+	threadID string // set after OpenThread succeeds; empty means no thread
+}
+
+type threadAction struct {
+	kind    actionKind
+	turnID  string
+	channel string // only for actionSpawn
+	chatID  string // only for actionSpawn
+	label   string // only for actionSpawn
+	payload any    // event payload
+}
+
+type actionKind int
+
+const (
+	actionSpawn actionKind = iota
+	actionEnd
+	actionOrphan
+	actionToolStart
+	actionToolEnd
+	actionLLMResponse
+	actionError
+)
+
+// SubTurnNotifier subscribes to EventBus subturn events and creates
+// Discord threads (or any ThreadCapable channel) to show subturn progress.
+// Single-use: create a new instance for each Start/Stop cycle.
+type SubTurnNotifier struct {
+	agentLoop *agent.AgentLoop
+	chanMgr   *channels.Manager
+
+	cancel   context.CancelFunc
+	wg       sync.WaitGroup
+	actionCh chan threadAction
+}
+
+func NewSubTurnNotifier(al *agent.AgentLoop, cm *channels.Manager) *SubTurnNotifier {
+	return &SubTurnNotifier{
+		agentLoop: al,
+		chanMgr:   cm,
+		actionCh:  make(chan threadAction, 64),
+	}
+}
+
+func (n *SubTurnNotifier) Start(ctx context.Context) {
+	ctx, n.cancel = context.WithCancel(ctx)
+	sub := n.agentLoop.SubscribeEvents(64)
+
+	n.wg.Add(2)
+
+	// eventLoop owns turnChannels, sends to actionCh, closes actionCh on exit.
+	go func() {
+		defer n.wg.Done()
+		defer n.agentLoop.UnsubscribeEvents(sub.ID)
+		defer close(n.actionCh)
+		n.eventLoop(ctx, sub)
+	}()
+
+	// workerLoop owns entries, reads actionCh until closed, drains remaining.
+	go func() {
+		defer n.wg.Done()
+		n.workerLoop(ctx)
+	}()
+
+	logger.InfoC("subturn_notifier", "SubTurn notifier started")
+}
+
+func (n *SubTurnNotifier) Stop() {
+	if n.cancel != nil {
+		n.cancel()
+	}
+	n.wg.Wait()
+	logger.InfoC("subturn_notifier", "SubTurn notifier stopped")
+}
+
+// eventLoop processes EventBus events, maintains turnChannels (plain map),
+// tracks known subturn IDs, and dispatches actions to workerLoop via actionCh.
+func (n *SubTurnNotifier) eventLoop(ctx context.Context, sub agent.EventSubscription) {
+	turnChannels := make(map[string]turnInfo)
+	subturnIDs := make(map[string]struct{})
+
+	for {
+		select {
+		case <-ctx.Done():
+			return
+		case evt, ok := <-sub.C:
+			if !ok {
+				return
+			}
+			n.handleEvent(ctx, evt, turnChannels, subturnIDs)
+		}
+	}
+}
+
+// workerLoop owns the entries map and executes Discord API calls.
+// Reads from actionCh until it is closed (drain on shutdown).
+func (n *SubTurnNotifier) workerLoop(ctx context.Context) {
+	entries := make(map[string]*subturnEntry)
+
+	for act := range n.actionCh {
+		n.executeAction(ctx, act, entries)
+	}
+}
+
+func (n *SubTurnNotifier) handleEvent(ctx context.Context, evt agent.Event, turnChannels map[string]turnInfo, subturnIDs map[string]struct{}) {
+	switch evt.Kind {
+	case agent.EventKindTurnStart:
+		if p, ok := evt.Payload.(agent.TurnStartPayload); ok {
+			turnChannels[evt.Meta.TurnID] = turnInfo{channel: p.Channel, chatID: p.ChatID}
+		}
+
+	case agent.EventKindTurnEnd:
+		delete(turnChannels, evt.Meta.TurnID)
+
+	case agent.EventKindSubTurnSpawn:
+		p, ok := evt.Payload.(agent.SubTurnSpawnPayload)
+		if !ok {
+			return
+		}
+		info, ok := turnChannels[p.ParentTurnID]
+		if !ok {
+			return
+		}
+		if n.threadCapableFor(info.channel) == nil {
+			return
+		}
+
+		subturnIDs[evt.Meta.TurnID] = struct{}{}
+
+		select {
+		case n.actionCh <- threadAction{
+			kind:    actionSpawn,
+			turnID:  evt.Meta.TurnID,
+			channel: info.channel,
+			chatID:  info.chatID,
+			label:   p.Label,
+		}:
+		case <-ctx.Done():
+		}
+
+	case agent.EventKindSubTurnEnd:
+		delete(subturnIDs, evt.Meta.TurnID)
+
+		select {
+		case n.actionCh <- threadAction{
+			kind:    actionEnd,
+			turnID:  evt.Meta.TurnID,
+			payload: evt.Payload,
+		}:
+		case <-ctx.Done():
+		}
+
+	case agent.EventKindSubTurnOrphan:
+		p, ok := evt.Payload.(agent.SubTurnOrphanPayload)
+		if !ok {
+			return
+		}
+
+		delete(subturnIDs, p.ChildTurnID)
+
+		select {
+		case n.actionCh <- threadAction{
+			kind:    actionOrphan,
+			turnID:  p.ChildTurnID,
+			payload: evt.Payload,
+		}:
+		case <-ctx.Done():
+		}
+
+	case agent.EventKindToolExecStart:
+		if _, ok := subturnIDs[evt.Meta.TurnID]; !ok {
+			return
+		}
+
+		select {
+		case n.actionCh <- threadAction{
+			kind:    actionToolStart,
+			turnID:  evt.Meta.TurnID,
+			payload: evt.Payload,
+		}:
+		case <-ctx.Done():
+		}
+
+	case agent.EventKindToolExecEnd:
+		if _, ok := subturnIDs[evt.Meta.TurnID]; !ok {
+			return
+		}
+
+		select {
+		case n.actionCh <- threadAction{
+			kind:    actionToolEnd,
+			turnID:  evt.Meta.TurnID,
+			payload: evt.Payload,
+		}:
+		case <-ctx.Done():
+		}
+
+	case agent.EventKindLLMResponse:
+		if _, ok := subturnIDs[evt.Meta.TurnID]; !ok {
+			return
+		}
+
+		select {
+		case n.actionCh <- threadAction{
+			kind:    actionLLMResponse,
+			turnID:  evt.Meta.TurnID,
+			payload: evt.Payload,
+		}:
+		case <-ctx.Done():
+		}
+
+	case agent.EventKindError:
+		if _, ok := subturnIDs[evt.Meta.TurnID]; !ok {
+			return
+		}
+
+		select {
+		case n.actionCh <- threadAction{
+			kind:    actionError,
+			turnID:  evt.Meta.TurnID,
+			payload: evt.Payload,
+		}:
+		case <-ctx.Done():
+		}
+	}
+}
+
+func (n *SubTurnNotifier) executeAction(ctx context.Context, act threadAction, entries map[string]*subturnEntry) {
+	switch act.kind {
+	case actionSpawn:
+		tc := n.threadCapableFor(act.channel)
+		if tc == nil {
+			return
+		}
+
+		threadName := normalizeThreadName(fmt.Sprintf("🔄 %s", act.label))
+		anchorMsg := fmt.Sprintf("🔄 **Subagent started**: `%s`", act.label)
+
+		threadID, err := tc.OpenThread(ctx, act.chatID, threadName, anchorMsg)
+		if err != nil {
+			logger.WarnCF("subturn_notifier", "Thread creation failed", map[string]any{
+				"error":    err.Error(),
+				"child_id": act.label,
+				"chat_id":  act.chatID,
+			})
+			// Entry stored with empty threadID — end/orphan will skip thread send.
+		}
+
+		entries[act.turnID] = &subturnEntry{
+			label:    act.label,
+			channel:  act.channel,
+			chatID:   act.chatID,
+			threadID: threadID,
+		}
+
+	case actionEnd:
+		entry, ok := entries[act.turnID]
+		if !ok {
+			return
+		}
+		delete(entries, act.turnID)
+
+		p, ok := act.payload.(agent.SubTurnEndPayload)
+		if !ok {
+			return
+		}
+
+		if entry.threadID == "" {
+			return
+		}
+
+		tc := n.threadCapableFor(entry.channel)
+		if tc == nil {
+			return
+		}
+
+		var msg string
+		if p.Status == "completed" {
+			msg = fmt.Sprintf("✅ **%s** completed", entry.label)
+		} else {
+			msg = fmt.Sprintf("❌ **%s** failed (status: %s)", entry.label, p.Status)
+		}
+
+		if _, err := tc.SendToThread(ctx, entry.threadID, msg); err != nil {
+			logger.ErrorCF("subturn_notifier", "Failed to send completion to thread", map[string]any{
+				"error":     err.Error(),
+				"thread_id": entry.threadID,
+			})
+		}
+
+	case actionOrphan:
+		p, ok := act.payload.(agent.SubTurnOrphanPayload)
+		if !ok {
+			return
+		}
+		entry, ok := entries[p.ChildTurnID]
+		if !ok {
+			return
+		}
+		delete(entries, p.ChildTurnID)
+
+		if entry.threadID == "" {
+			return
+		}
+
+		tc := n.threadCapableFor(entry.channel)
+		if tc == nil {
+			return
+		}
+
+		msg := fmt.Sprintf("⚠️ **%s** orphaned: %s", entry.label, sanitizeDiscordMentions(p.Reason))
+		if _, err := tc.SendToThread(ctx, entry.threadID, msg); err != nil {
+			logger.ErrorCF("subturn_notifier", "Failed to send orphan notice to thread", map[string]any{
+				"error":     err.Error(),
+				"thread_id": entry.threadID,
+			})
+		}
+
+	case actionToolStart:
+		entry, ok := entries[act.turnID]
+		if !ok || entry.threadID == "" {
+			return
+		}
+
+		tc := n.threadCapableFor(entry.channel)
+		if tc == nil {
+			return
+		}
+
+		p, ok := act.payload.(agent.ToolExecStartPayload)
+		if !ok {
+			return
+		}
+
+		msg := fmt.Sprintf("🔧 `%s`", p.Tool)
+		if len(p.Arguments) > 0 {
+			argsJSON, err := json.Marshal(p.Arguments)
+			if err == nil {
+				preview := sanitizeDiscordMentions(truncateString(string(argsJSON), 200))
+				msg += fmt.Sprintf("\n```json\n%s\n```", preview)
+			}
+		}
+
+		if _, err := tc.SendToThread(ctx, entry.threadID, msg); err != nil {
+			logger.WarnCF("subturn_notifier", "Failed to send tool start to thread", map[string]any{
+				"error":     err.Error(),
+				"thread_id": entry.threadID,
+				"tool":      p.Tool,
+			})
+		}
+
+	case actionToolEnd:
+		entry, ok := entries[act.turnID]
+		if !ok || entry.threadID == "" {
+			return
+		}
+
+		tc := n.threadCapableFor(entry.channel)
+		if tc == nil {
+			return
+		}
+
+		p, ok := act.payload.(agent.ToolExecEndPayload)
+		if !ok {
+			return
+		}
+
+		duration := p.Duration.Round(100 * time.Millisecond)
+		var msg string
+		if p.IsError {
+			msg = fmt.Sprintf("❌ `%s` failed (%s)", p.Tool, duration)
+		} else {
+			msg = fmt.Sprintf("✅ `%s` (%s)", p.Tool, duration)
+		}
+
+		if _, err := tc.SendToThread(ctx, entry.threadID, msg); err != nil {
+			logger.WarnCF("subturn_notifier", "Failed to send tool end to thread", map[string]any{
+				"error":     err.Error(),
+				"thread_id": entry.threadID,
+				"tool":      p.Tool,
+			})
+		}
+
+	case actionLLMResponse:
+		entry, ok := entries[act.turnID]
+		if !ok || entry.threadID == "" {
+			return
+		}
+
+		tc := n.threadCapableFor(entry.channel)
+		if tc == nil {
+			return
+		}
+
+		p, ok := act.payload.(agent.LLMResponsePayload)
+		if !ok {
+			return
+		}
+
+		var parts []string
+		parts = append(parts, fmt.Sprintf("%d chars", p.ContentLen))
+		if p.ToolCalls > 0 {
+			parts = append(parts, fmt.Sprintf("%d tool calls", p.ToolCalls))
+		}
+		if p.HasReasoning {
+			parts = append(parts, "reasoning")
+		}
+		msg := fmt.Sprintf("💬 LLM responded (%s)", strings.Join(parts, ", "))
+
+		if _, err := tc.SendToThread(ctx, entry.threadID, msg); err != nil {
+			logger.WarnCF("subturn_notifier", "Failed to send LLM response to thread", map[string]any{
+				"error":     err.Error(),
+				"thread_id": entry.threadID,
+			})
+		}
+
+	case actionError:
+		entry, ok := entries[act.turnID]
+		if !ok || entry.threadID == "" {
+			return
+		}
+
+		tc := n.threadCapableFor(entry.channel)
+		if tc == nil {
+			return
+		}
+
+		p, ok := act.payload.(agent.ErrorPayload)
+		if !ok {
+			return
+		}
+
+		msg := fmt.Sprintf("❗ Error [%s]: %s", p.Stage, sanitizeDiscordMentions(truncateString(p.Message, 300)))
+
+		if _, err := tc.SendToThread(ctx, entry.threadID, msg); err != nil {
+			logger.WarnCF("subturn_notifier", "Failed to send error to thread", map[string]any{
+				"error":     err.Error(),
+				"thread_id": entry.threadID,
+			})
+		}
+	}
+}
+
+func (n *SubTurnNotifier) threadCapableFor(channelName string) channels.ThreadCapable {
+	ch, ok := n.chanMgr.GetChannel(channelName)
+	if !ok {
+		return nil
+	}
+	tc, ok := ch.(channels.ThreadCapable)
+	if !ok {
+		return nil
+	}
+	return tc
+}
+
+// normalizeThreadName sanitizes a thread name for Discord:
+// - strips control characters and excessive whitespace
+// - falls back to "subagent" if empty
+// - truncates to 100 runes (Discord limit)
+func normalizeThreadName(name string) string {
+	name = strings.Map(func(r rune) rune {
+		if unicode.IsControl(r) {
+			return ' '
+		}
+		return r
+	}, name)
+	name = strings.Join(strings.Fields(name), " ")
+	if name == "" {
+		name = "subagent"
+	}
+	runes := []rune(name)
+	if len(runes) > 100 {
+		return string(runes[:97]) + "..."
+	}
+	return name
+}
+
+func truncateString(s string, maxLen int) string {
+	runes := []rune(s)
+	if len(runes) <= maxLen {
+		return s
+	}
+	return string(runes[:maxLen]) + "…"
+}
+
+var discordMentionReplacer = strings.NewReplacer(
+	"@everyone", "@\u200beveryone",
+	"@here", "@\u200bhere",
+)
+
+func sanitizeDiscordMentions(s string) string {
+	return discordMentionReplacer.Replace(s)
+}
