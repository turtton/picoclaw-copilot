+// ThreadCapable — channels that can create and send messages to threads.
+// OpenThread creates a new thread in the given channel with an initial anchor
+// message and returns the thread ID. SendToThread posts a follow-up message
+// to an existing thread.
+type ThreadCapable interface {
+	OpenThread(ctx context.Context, channelID, name, initialMessage string) (threadID string, err error)
+	SendToThread(ctx context.Context, threadID, content string) (messageID string, err error)
+}
