index 0000000..1eef400
--- /dev/null
+++ b/pkg/tools/opencode_task.go
@@ -0,0 +1,168 @@
+package tools
+
+import (
+	"bytes"
+	"context"
+	"encoding/json"
+	"fmt"
+	"io"
+	"net/http"
+	"strings"
+	"time"
+)
+
+type OpenCodeTaskTool struct {
+	serverURL string
+	username  string
+	password  string
+	client    *http.Client
+}
+
+func NewOpenCodeTaskTool(serverURL, username, password string) *OpenCodeTaskTool {
+	serverURL = strings.TrimRight(serverURL, "/")
+	return &OpenCodeTaskTool{
+		serverURL: serverURL,
+		username:  username,
+		password:  password,
+		client: &http.Client{
+			Timeout: 10 * time.Minute,
+		},
+	}
+}
+
+func (t *OpenCodeTaskTool) Name() string { return "opencode_task" }
+
+func (t *OpenCodeTaskTool) Description() string {
+	return "Delegate a coding task to an opencode agent. The agent has full access to the workspace and can read/write files, run commands, and use tools. Returns the agent's response. Use this for complex coding tasks that benefit from an autonomous coding agent."
+}
+
+func (t *OpenCodeTaskTool) Parameters() map[string]any {
+	return map[string]any{
+		"type": "object",
+		"properties": map[string]any{
+			"prompt": map[string]any{
+				"type":        "string",
+				"description": "The task description or prompt for the opencode agent. Be specific about what needs to be done, which files to modify, and expected outcomes.",
+			},
+		},
+		"required": []string{"prompt"},
+	}
+}
+
+func (t *OpenCodeTaskTool) Execute(ctx context.Context, args map[string]any) *ToolResult {
+	prompt, _ := args["prompt"].(string)
+	if strings.TrimSpace(prompt) == "" {
+		return ErrorResult("prompt is required")
+	}
+
+	sessionID, err := t.createSession(ctx)
+	if err != nil {
+		return ErrorResult(fmt.Sprintf("failed to create opencode session: %v", err))
+	}
+
+	response, err := t.sendMessage(ctx, sessionID, prompt)
+	if err != nil {
+		return ErrorResult(fmt.Sprintf("opencode task failed: %v", err))
+	}
+
+	return NewToolResult(fmt.Sprintf("opencode agent response (session %s):\n\n%s", sessionID, response))
+}
+
+func (t *OpenCodeTaskTool) createSession(ctx context.Context) (string, error) {
+	body, err := json.Marshal(map[string]any{})
+	if err != nil {
+		return "", fmt.Errorf("marshal request: %w", err)
+	}
+
+	req, err := http.NewRequestWithContext(ctx, http.MethodPost, t.serverURL+"/session", bytes.NewReader(body))
+	if err != nil {
+		return "", fmt.Errorf("create request: %w", err)
+	}
+	req.Header.Set("Content-Type", "application/json")
+	t.setAuth(req)
+
+	resp, err := t.client.Do(req)
+	if err != nil {
+		return "", fmt.Errorf("http request: %w", err)
+	}
+	defer resp.Body.Close()
+
+	if resp.StatusCode != http.StatusOK && resp.StatusCode != http.StatusCreated {
+		respBody, _ := io.ReadAll(resp.Body)
+		return "", fmt.Errorf("unexpected status %d: %s", resp.StatusCode, string(respBody))
+	}
+
+	var result struct {
+		ID string `json:"id"`
+	}
+	if err := json.NewDecoder(resp.Body).Decode(&result); err != nil {
+		return "", fmt.Errorf("decode response: %w", err)
+	}
+	if result.ID == "" {
+		return "", fmt.Errorf("empty session ID in response")
+	}
+
+	return result.ID, nil
+}
+
+func (t *OpenCodeTaskTool) sendMessage(ctx context.Context, sessionID, prompt string) (string, error) {
+	body, err := json.Marshal(map[string]any{
+		"parts": []map[string]any{
+			{"type": "text", "text": prompt},
+		},
+	})
+	if err != nil {
+		return "", fmt.Errorf("marshal request: %w", err)
+	}
+
+	url := fmt.Sprintf("%s/session/%s/message", t.serverURL, sessionID)
+	req, err := http.NewRequestWithContext(ctx, http.MethodPost, url, bytes.NewReader(body))
+	if err != nil {
+		return "", fmt.Errorf("create request: %w", err)
+	}
+	req.Header.Set("Content-Type", "application/json")
+	t.setAuth(req)
+
+	resp, err := t.client.Do(req)
+	if err != nil {
+		return "", fmt.Errorf("http request: %w", err)
+	}
+	defer resp.Body.Close()
+
+	if resp.StatusCode != http.StatusOK {
+		respBody, _ := io.ReadAll(resp.Body)
+		return "", fmt.Errorf("unexpected status %d: %s", resp.StatusCode, string(respBody))
+	}
+
+	var message struct {
+		Info struct {
+			Role string `json:"role"`
+		} `json:"info"`
+		Parts []struct {
+			Type string `json:"type"`
+			Text string `json:"text,omitempty"`
+		} `json:"parts"`
+	}
+	if err := json.NewDecoder(resp.Body).Decode(&message); err != nil {
+		return "", fmt.Errorf("decode response: %w", err)
+	}
+
+	var parts []string
+	for _, p := range message.Parts {
+		if p.Type == "text" && strings.TrimSpace(p.Text) != "" {
+			parts = append(parts, p.Text)
+		}
+	}
+
+	if len(parts) == 0 {
+		return "(no text response from opencode agent)", nil
+	}
+
+	return strings.Join(parts, "\n\n"), nil
+}
+
+func (t *OpenCodeTaskTool) setAuth(req *http.Request) {
+	if t.username != "" || t.password != "" {
+		req.SetBasicAuth(t.username, t.password)
+	}
+}
