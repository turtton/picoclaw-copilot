+func (c *DiscordChannel) handleInteraction(s *discordgo.Session, i *discordgo.InteractionCreate) {
+	if i.Type != discordgo.InteractionApplicationCommand {
+		return
+	}
+
+	data := i.ApplicationCommandData()
+	if data.Name != "clear" {
+		return
+	}
+
+	user := i.User
+	if user == nil && i.Member != nil {
+		user = i.Member.User
+	}
+	if user == nil {
+		logger.WarnCF("discord", "Received /clear interaction with no user information", map[string]any{"interaction_id": i.ID})
+		return
+	}
+
+	sender := bus.SenderInfo{
+		Platform:    "discord",
+		PlatformID:  user.ID,
+		CanonicalID: identity.BuildCanonicalID("discord", user.ID),
+		Username:    user.Username,
+		DisplayName: user.Username,
+	}
+
+	if !c.IsAllowedSender(sender) {
+		if err := c.session.InteractionRespond(i.Interaction, &discordgo.InteractionResponse{
+			Type: discordgo.InteractionResponseChannelMessageWithSource,
+			Data: &discordgo.InteractionResponseData{
+				Content: "You are not allowed to use this command.",
+				Flags:   discordgo.MessageFlagsEphemeral,
+			},
+		}); err != nil {
+			logger.WarnCF("discord", "Failed to respond to unauthorized /clear interaction", map[string]any{"error": err.Error()})
+		}
+		return
+	}
+
+	channelID := i.ChannelID
+	senderID := user.ID
+
+	peerKind := "channel"
+	peerID := channelID
+	if i.GuildID == "" {
+		peerKind = "direct"
+		peerID = senderID
+	}
+
+	peer := bus.Peer{Kind: peerKind, ID: peerID}
+
+	metadata := map[string]string{
+		"user_id":        senderID,
+		"username":       user.Username,
+		"display_name":   sender.DisplayName,
+		"guild_id":       i.GuildID,
+		"channel_id":     channelID,
+		"is_dm":          fmt.Sprintf("%t", i.GuildID == ""),
+		"interaction_id": i.ID,
+	}
+
+	if err := c.session.InteractionRespond(i.Interaction, &discordgo.InteractionResponse{
+		Type: discordgo.InteractionResponseChannelMessageWithSource,
+		Data: &discordgo.InteractionResponseData{
+			Content: "Clearing chat history...",
+			Flags:   discordgo.MessageFlagsEphemeral,
+		},
+	}); err != nil {
+		logger.WarnCF("discord", "Failed to acknowledge /clear interaction", map[string]any{"error": err.Error()})
+		return
+	}
+
+	c.HandleMessage(c.ctx, peer, "", senderID, channelID, "/clear", nil, metadata, sender)
+}
