+	// If the Copilot CLI has discarded our session (idle timeout or CLI
+	// restart), transparently recreate it and retry once. Without this, the
+	// provider would keep failing with the same stale session ID until the
+	// whole pod is restarted.
+	if err != nil && isSessionNotFoundError(err) {
+		newSession, recreateErr := p.recreateSession(ctx)
+		if recreateErr != nil {
+			return nil, fmt.Errorf("failed to send message to copilot: %w (and failed to recreate session: %v)", err, recreateErr)
+		}
+		resp, err = newSession.SendAndWait(ctx, copilot.MessageOptions{
+			Prompt: string(fullcontent),
+		})
+	}
 	if err != nil {
 		return nil, fmt.Errorf("failed to send message to copilot: %w", err)
 	}
