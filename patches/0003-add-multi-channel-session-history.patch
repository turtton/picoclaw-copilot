+		base := strings.TrimSuffix(name, ".meta.json")
+		jsonlPath := filepath.Join(dir, base+".jsonl")
+		if _, statErr := os.Stat(jsonlPath); statErr != nil {
+			continue
+		}
+
+		if _, exists := seen[base]; exists {
