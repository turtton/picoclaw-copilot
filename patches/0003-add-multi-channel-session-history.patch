+		return nonPicoSessionRef{}, os.ErrNotExist
+	}
+
+	metaPath := filepath.Join(dir, sanitizedKey+".meta.json")
+	meta, err := h.readSessionMeta(metaPath, sanitizedKey)
+	if err != nil {
+		return nonPicoSessionRef{}, err
+	}
+
+	channel := channelFromMeta(meta)
+	if channel == "" || strings.EqualFold(channel, "pico") {
+		return nonPicoSessionRef{}, os.ErrNotExist
+	}
+
+	key := meta.Key
+	if key == "" {
+		key = sanitizedKey
+	}
+
+	return nonPicoSessionRef{
+		SanitizedKey: sanitizedKey,
+		Key:          key,
+		Channel:      channel,
+	}, nil
+}
