+func TestIsSessionKey(t *testing.T) {
+	tests := []struct {
+		key    string
+		wantID string
+		wantOK bool
+	}{
+		{"agent:main:discord:direct:123", "agent_main_discord_direct_123", true},
+		{"agent:main:whatsapp_native:direct:456", "agent_main_whatsapp_native_direct_456", true},
+		{"agent:main:pico:direct:pico:abc", "agent_main_pico_direct_pico_abc", true},
+		{"agent_main_discord_direct_123", "agent_main_discord_direct_123", true},
+		{"agent_main_whatsapp_native_direct_456", "agent_main_whatsapp_native_direct_456", true},
+		{"agent:main:", "", false},
+		{"agent_main_", "", false},
+		{"unrelated-file", "", false},
+		{"", "", false},
+	}
+
+	for _, tt := range tests {
+		sanitizedID, ok := isSessionKey(tt.key)
+		if ok != tt.wantOK {
+			t.Errorf("isSessionKey(%q) ok = %v, want %v", tt.key, ok, tt.wantOK)
+		}
+		if sanitizedID != tt.wantID {
+			t.Errorf("isSessionKey(%q) = %q, want %q", tt.key, sanitizedID, tt.wantID)
+		}
+	}
+}
