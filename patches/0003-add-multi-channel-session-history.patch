+func TestChannelFromSessionKey(t *testing.T) {
+	tests := []struct {
+		key  string
+		want string
+	}{
+		{"agent:main:discord:direct:123", "discord"},
+		{"agent:main:whatsapp_native:direct:456", "whatsapp_native"},
+		{"agent:main:pico:direct:pico:abc", "pico"},
+		{"agent:main:telegram:channel:789", "telegram"},
+		{"agent_main_discord_direct_123", "discord"},
+		{"agent_main_pico_direct_pico_abc", "pico"},
+		{"agent_main_", ""},
+		{"unrelated", ""},
+		{"agent:main:", ""},
+		{"", ""},
+	}
+
+	for _, tt := range tests {
+		got := channelFromSessionKey(tt.key)
+		if got != tt.want {
+			t.Errorf("channelFromSessionKey(%q) = %q, want %q", tt.key, got, tt.want)
+		}
+	}
+}
