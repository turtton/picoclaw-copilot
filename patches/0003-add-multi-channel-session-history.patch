+// channelFromSessionKey extracts the channel name from a session key.
+// It first tries the unsanitized colon-separated form
+// ("agent:main:discord:direct:123"), then falls back to the sanitized
+// underscore-separated form ("agent_main_discord_direct_123").
+func channelFromSessionKey(key string) string {
+	const sessionKeyPrefix = "agent:main:"
+	const sanitizedSessionKeyPrefix = "agent_main_"
+	if strings.HasPrefix(key, sessionKeyPrefix) {
+		rest := strings.TrimPrefix(key, sessionKeyPrefix)
+		parts := strings.SplitN(rest, ":", 2)
+		if len(parts) >= 2 && parts[0] != "" {
+			return parts[0]
+		}
+	}
+	if strings.HasPrefix(key, sanitizedSessionKeyPrefix) {
+		rest := strings.TrimPrefix(key, sanitizedSessionKeyPrefix)
+		parts := strings.SplitN(rest, "_", 2)
+		if len(parts) >= 2 && parts[0] != "" {
+			return parts[0]
+		}
+	}
+	return ""
+}
+
+// isValidSessionID checks that the session ID is safe for filesystem use.
+// It rejects empty strings, absolute paths, and any path containing
+// directory separators or ".." components to prevent traversal attacks.
+func isValidSessionID(id string) bool {
+	if id == "" || id == "." || id == ".." {
+		return false
+	}
+	if strings.ContainsAny(id, "/\\") {
+		return false
+	}
+	if strings.Contains(id, "..") {
+		return false
+	}
+	return true
+}
